PORT=3000
ADMIN_USER=admin@example.local
ADMIN_PASS=change-me-local-admin-password
JWT_SECRET=change-me-local-jwt-secret
CORS_ORIGIN=http://localhost:5173

# Neon normalmente entrega sslmode=require. Para este proyecto, sustitúyelo por sslmode=verify-full.
# Conserva channel_binding=require en la URL; la versión actual de pg no lo aplica explícitamente.
# Ejemplo ficticio pooled (hostname terminado en -pooler):
# DATABASE_URL=postgresql://acalogos_app:replace-with-password@ep-example-123456-pooler.us-east-2.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require
# DATABASE_URL tiene precedencia sobre DB_*.
DATABASE_URL=

# Reservada para futuras tareas administrativas; la aplicación todavía no la utiliza.
# Ejemplo ficticio directo:
# DIRECT_DATABASE_URL=postgresql://acalogos_admin:replace-with-password@ep-example-123456.us-east-2.aws.neon.tech/neondb?sslmode=verify-full&channel_binding=require
DIRECT_DATABASE_URL=

# Desarrollo local con PostgreSQL 14 por Docker.
DB_HOST=localhost
DB_PORT=5432
DB_USER=acalogos_local_user
DB_PASSWORD=change-me-local-db-password
DB_NAME=acalogos_local_db
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Formulario de contacto. La ruta no se monta mientras CONTACT_ENABLED sea false.
CONTACT_ENABLED=false
# Al activar, use únicamente identidades verificadas en el proveedor.
CONTACT_TO_EMAIL=contact@example.test
CONTACT_FROM_EMAIL=sender@example.test
BREVO_API_KEY=replace-with-brevo-api-key
CONTACT_PRIVACY_NOTICE_VERSION=contact-v1

# Límites opcionales; si se omiten se usan los valores seguros documentados.
# CONTACT_EMAIL_TIMEOUT_MS=5000
# CONTACT_RATE_LIMIT_WINDOW_MS=900000
# CONTACT_RATE_LIMIT_MAX=100
# Circuit breaker provisional: todas las personas comparten esta cuota global.
# No reemplaza una protección por IP. Antes de implementarla se debe validar de
# forma controlada la topología de proxies de Render; entonces podrá reducirse
# CONTACT_RATE_LIMIT_MAX usando una clave segura por visitante.
